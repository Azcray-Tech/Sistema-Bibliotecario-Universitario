<div class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <button class="sidebar-toggle-btn" onclick="toggleSidebar()" title="Colapsar sidebar">
            <i class="bi bi-chevron-left"></i>
        </button>
        <h4><i class="bi bi-book-half me-2"></i><span class="menu-text">Sistema Bibliográfico</span></h4>
        <div class="user-info">
            <i class="bi bi-person-circle me-1"></i><span class="menu-text"><%= admin.nombre %></span>
        </div>
    </div>
    <div class="sidebar-menu">
        <div class="menu-section">Panel Principal</div>
        <a href="/admin/dashboard" class="menu-item <%= page==='dashboard' ? 'active' : '' %>">
            <i class="bi bi-speedometer2"></i><span class="menu-text">Dashboard</span>
        </a>
        <div class="menu-section">Gestión de Contenido</div>
        <a href="/admin/catalogo" class="menu-item <%= page==='catalogo' ? 'active' : '' %>">
            <i class="bi bi-book"></i><span class="menu-text">Biblioteca</span>
        </a>
        <a href="/admin/catalogo/nuevo" class="menu-item <%= page==='catalogo-nuevo' ? 'active' : '' %>">
            <i class="bi bi-plus-circle"></i><span class="menu-text">Agregar Material</span>
        </a>
        <a href="/admin/categorias" class="menu-item <%= page==='categorias' ? 'active' : '' %>">
            <i class="bi bi-tags"></i><span class="menu-text">Categorías</span>
        </a>
        <div class="menu-section">Préstamos</div>
        <a href="/admin/prestamos" class="menu-item <%= page==='prestamos' ? 'active' : '' %>">
            <i class="bi bi-arrow-left-right"></i><span class="menu-text">Gestión de Préstamos</span>
        </a>
        <a href="/admin/prestamos/historial" class="menu-item <%= page==='historial' ? 'active' : '' %>">
            <i class="bi bi-clock-history"></i><span class="menu-text">Historial</span>
        </a>
        <a href="/admin/prestamos/sanciones" class="menu-item <%= page==='sanciones' ? 'active' : '' %>">
            <i class="bi bi-exclamation-triangle"></i><span class="menu-text">Retrasos y Sanciones</span>
        </a>
        <div class="menu-section">Reportes</div>
        <a href="/admin/informes" class="menu-item <%= page==='informes' ? 'active' : '' %>">
            <i class="bi bi-file-earmark-bar-graph"></i><span class="menu-text">Generar Informes</span>
        </a>
        <a href="/admin/inventario" class="menu-item <%= page==='inventario' ? 'active' : '' %>">
            <i class="bi bi-box-seam"></i><span class="menu-text">Inventario</span>
        </a>
        <div class="menu-section">Sistema</div>
        <a href="/admin/usuarios" class="menu-item <%= page==='usuarios' ? 'active' : '' %>">
            <i class="bi bi-people"></i><span class="menu-text">Usuarios</span>
        </a>
        <a href="/admin/backup" class="menu-item <%= page==='backup' ? 'active' : '' %>">
            <i class="bi bi-database"></i><span class="menu-text">Backup</span>
        </a>
        <a href="/admin/configuracion" class="menu-item <%= page==='configuracion' ? 'active' : '' %>">
            <i class="bi bi-gear"></i><span class="menu-text">Configuración</span>
        </a>
    </div>
    <a href="/admin/logout" class="logout-btn">
        <i class="bi bi-box-arrow-left"></i><span class="menu-text">Cerrar Sesión</span>
    </a>
</div>

<script>
function toggleSidebar() {
    const sidebar = document.getElementById('sidebar');
    const body = document.body;
    const toggleBtn = document.querySelector('.sidebar-toggle-btn i');
    sidebar.classList.toggle('collapsed');
    body.classList.toggle('sidebar-collapsed');
    if (toggleBtn) {
        if (sidebar.classList.contains('collapsed')) {
            toggleBtn.classList.remove('bi-chevron-left');
            toggleBtn.classList.add('bi-list');
        } else {
            toggleBtn.classList.remove('bi-list');
            toggleBtn.classList.add('bi-chevron-left');
        }
    }
    localStorage.setItem('sidebarCollapsed', sidebar.classList.contains('collapsed'));
}

// Restaurar estado al cargar
document.addEventListener('DOMContentLoaded', function() {
    if (localStorage.getItem('sidebarCollapsed') === 'true') {
        document.getElementById('sidebar').classList.add('collapsed');
        document.body.classList.add('sidebar-collapsed');
        const toggleBtn = document.querySelector('.sidebar-toggle-btn i');
        if (toggleBtn) {
            toggleBtn.classList.remove('bi-chevron-left');
            toggleBtn.classList.add('bi-list');
        }
    }
});
</script>
