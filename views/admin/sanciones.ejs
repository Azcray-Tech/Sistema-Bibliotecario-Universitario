<!DOCTYPE html>
<html lang="es">
<head><title>Retrasos y Sanciones - Sistema Bibliográfico</title><%- include('../partials/head') %></head>
<body>
<div class="admin-wrapper">
    <%- include('../partials/sidebar', {page:'sanciones'}) %>
    <div class="main-content">
        <div class="top-bar"><h2><i class="bi bi-exclamation-triangle me-2"></i>Retrasos y Sanciones</h2></div>
        <div class="content-card">
            <h5 class="mb-3">Préstamos vencidos y usuarios sancionados</h5>
            <div class="table-responsive">
                <table class="table table-custom">
                    <thead>
                        <tr><th>Usuario</th><th>Cédula</th><th>Material</th><th>Días de retraso</th><th>Suspendido hasta</th></tr>
                    </thead>
                    <tbody>
                        <% prestamosVencidos.forEach(p => { %>
                        <tr>
                            <td><%= p.Usuario ? p.Usuario.nombre : '-' %></td>
                            <td><%= p.Usuario ? p.Usuario.cedula : '-' %></td>
                            <td><%= p.Material ? p.Material.titulo.substring(0,45) : '-' %></td>
                            <td><span class="badge bg-danger"><%= p.dias_retraso %> días</span></td>
                            <td>
                                <% if (p.Usuario && p.Usuario.suspendido_hasta) { %>
                                    <span class="badge bg-warning"><%= new Date(p.Usuario.suspendido_hasta).toLocaleDateString('es-VE') %></span>
                                <% } else { %>-<% } %>
                            </td>
                        </tr>
                        <% }) %>
                        <% if (prestamosVencidos.length===0) { %>
                            <tr><td colspan="5" class="text-center text-muted py-4"><i class="bi bi-check-circle me-2"></i>No hay préstamos vencidos</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
</body>
</html>
