<!DOCTYPE html>
<html lang="es">
<head><title>Dashboard - Sistema Bibliográfico</title><%- include('../partials/head') %></head>
<body>
<div class="admin-wrapper">
    <%- include('../partials/sidebar', {page:'dashboard'}) %>
    <div class="main-content">

        <div class="top-bar">
            <div>
                <h2>Panel Administrativo</h2>
                <small class="text-muted">
                    <%= new Date().toLocaleDateString('es-VE', {weekday:'long', year:'numeric', month:'long', day:'numeric'}) %>
                    &nbsp;·&nbsp; Bienvenido, <%= admin.nombre %>
                </small>
            </div>
            <a href="/admin/catalogo/nuevo" class="btn btn-primary-custom">
                <i class="bi bi-plus-lg me-2"></i>Agregar Material
            </a>
        </div>

        <!-- Alerta vencidos (solo si hay) -->
        <% if (vencidos > 0) { %>
        <div class="alert alert-danger d-flex align-items-center justify-content-between mb-4" role="alert">
            <div>
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <strong><%= vencidos %> préstamo(s) vencido(s)</strong> — se requiere atención inmediata.
            </div>
            <a href="/admin/prestamos/sanciones" class="btn btn-sm btn-danger">Ver ahora</a>
        </div>
        <% } %>

        <!-- Estadísticas -->
        <div class="stats-grid-6">
            <div class="stat-card accent-1">
                <div class="stat-icon"><i class="bi bi-book-fill"></i></div>
                <div class="stat-value"><%= totalMateriales %></div>
                <div class="stat-label">Títulos en catálogo</div>
            </div>
            <div class="stat-card accent-2">
                <div class="stat-icon"><i class="bi bi-collection-fill"></i></div>
                <div class="stat-value"><%= totalEjemplares %></div>
                <div class="stat-label">Ejemplares totales</div>
            </div>
            <div class="stat-card accent-3">
                <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
                <div class="stat-value"><%= totalUsuarios %></div>
                <div class="stat-label">Usuarios registrados</div>
            </div>
            <div class="stat-card accent-2">
                <div class="stat-icon"><i class="bi bi-arrow-left-right"></i></div>
                <div class="stat-value"><%= prestamosActivos %></div>
                <div class="stat-label">Préstamos activos</div>
            </div>
            <div class="stat-card accent-3">
                <div class="stat-icon"><i class="bi bi-check-circle-fill"></i></div>
                <div class="stat-value"><%= disponibles %></div>
                <div class="stat-label">Disponibles ahora</div>
            </div>
            <div class="stat-card accent-4">
                <div class="stat-icon"><i class="bi bi-exclamation-circle-fill"></i></div>
                <div class="stat-value"><%= vencidos %></div>
                <div class="stat-label">Préstamos vencidos</div>
            </div>
        </div>

        <!-- Actividad reciente -->
        <div class="content-card mt-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0"><i class="bi bi-clock-history me-2"></i>Actividad Reciente</h4>
                <a href="/admin/prestamos/historial" class="btn btn-sm btn-outline-secondary">Ver historial completo</a>
            </div>
            <% if (!ultimosPrestamos || ultimosPrestamos.length === 0) { %>
                <p class="text-muted text-center py-4"><i class="bi bi-inbox me-2"></i>No hay préstamos registrados aún.</p>
            <% } else { %>
            <div class="table-responsive">
                <table class="table table-custom">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Usuario</th>
                            <th>Cédula</th>
                            <th>Material</th>
                            <th>Ejemplar</th>
                            <th>Devolución</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% ultimosPrestamos.forEach(p => {
                            const hoy  = new Date();
                            const dev  = new Date(p.fecha_devolucion);
                            const diff = Math.floor((hoy - dev) / 86400000);
                        %>
                        <tr>
                            <td><small><%= new Date(p.createdAt).toLocaleDateString('es-VE') %></small></td>
                            <td><%= p.Usuario ? p.Usuario.nombre + ' ' + p.Usuario.apellido : '-' %></td>
                            <td><small class="text-muted"><%= p.Usuario ? p.Usuario.cedula : '-' %></small></td>
                            <td><%= p.Ejemplar?.Material ? p.Ejemplar.Material.titulo.substring(0,35) + (p.Ejemplar.Material.titulo.length > 35 ? '...' : '') : '-' %></td>
                            <td><small class="text-muted"><code><%= p.Ejemplar ? p.Ejemplar.codigo_inventario : '-' %></code></small></td>
                            <td><small><%= dev.toLocaleDateString('es-VE') %></small></td>
                            <td>
                                <% if (p.estado === 'devuelto') { %>
                                    <span class="badge bg-primary">Devuelto</span>
                                <% } else if (diff > 0) { %>
                                    <span class="badge bg-danger">Vencido — <%= diff %>d</span>
                                <% } else if (diff >= -2) { %>
                                    <span class="badge bg-warning text-dark">Por vencer</span>
                                <% } else { %>
                                    <span class="badge bg-success">Activo</span>
                                <% } %>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <% } %>
        </div>

        <!-- Fila inferior: acciones + estadísticas categoría -->
        <div class="row g-4 mt-1">
            <div class="col-md-4">
                <div class="content-card h-100">
                    <h4><i class="bi bi-lightning-fill me-2"></i>Acciones Rápidas</h4>
                    <div class="d-grid gap-2 mt-3">
                        <a href="/admin/catalogo/nuevo" class="btn btn-outline-primary">
                            <i class="bi bi-plus-circle me-2"></i>Agregar Nuevo Material
                        </a>
                        <a href="/admin/prestamos" class="btn btn-outline-success">
                            <i class="bi bi-arrow-left-right me-2"></i>Registrar Préstamo
                        </a>
                        <a href="/admin/informes" class="btn btn-outline-info">
                            <i class="bi bi-file-earmark-text me-2"></i>Generar Informe
                        </a>
                        <a href="/admin/usuarios" class="btn btn-outline-secondary">
                            <i class="bi bi-people me-2"></i>Gestión de Usuarios
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="content-card h-100">
                    <h4><i class="bi bi-pie-chart-fill me-2"></i>Materiales por Tipo</h4>
                    <% const totalTipos = porTipo.reduce((s,t) => s + parseInt(t.total), 0) || 1;
                       const coloresTipo = ['var(--color-primary)','var(--color-secondary)','var(--color-accent)','#17a2b8'];
                    %>
                    <div class="mt-3">
                    <% porTipo.forEach((t, i) => { %>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span><i class="bi bi-circle-fill me-2" style="font-size:.6rem;color:<%= coloresTipo[i] || '#aaa' %>"></i><%= t.tipo.charAt(0).toUpperCase()+t.tipo.slice(1) %>s</span>
                                <strong><%= t.total %></strong>
                            </div>
                            <div class="progress" style="height:8px;">
                                <div class="progress-bar" style="width:<%= Math.round(parseInt(t.total)/totalTipos*100) %>%;background:<%= coloresTipo[i] || '#aaa' %>;"></div>
                            </div>
                        </div>
                    <% }) %>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="content-card h-100">
                    <h4><i class="bi bi-graph-up me-2"></i>Más Solicitados</h4>
                    <% if (!masSolicitados || masSolicitados.length === 0) { %>
                        <p class="text-muted mt-3">Sin datos de préstamos aún.</p>
                    <% } else { %>
                    <div class="mt-3">
                        <% masSolicitados.forEach((d, i) => { %>
                        <div class="d-flex align-items-start gap-2 mb-3">
                            <span class="badge rounded-pill bg-secondary" style="min-width:24px;text-align:center;"><%= i+1 %></span>
                            <div>
                                <div style="font-size:.88rem;font-weight:600;line-height:1.3;">
                                    <%= d.Ejemplar?.Material?.titulo?.substring(0,45) || '-' %>
                                </div>
                                <small class="text-muted"><%= d.dataValues.total %> préstamo(s)</small>
                            </div>
                        </div>
                        <% }) %>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>

    </div>
</div>
</body>
</html>