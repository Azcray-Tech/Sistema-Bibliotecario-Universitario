<!DOCTYPE html>
<html lang="es">
<head><title>Backup - Sistema Bibliográfico</title><%- include('../partials/head') %></head>
<body>
<div class="admin-wrapper">
    <%- include('../partials/sidebar', {page:'backup'}) %>
    <div class="main-content">
        <div class="top-bar">
            <h2><i class="bi bi-database me-2"></i>Backup del Sistema</h2>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i><%= error %></div>
        <% } %>
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="alert alert-success"><i class="bi bi-check-circle me-2"></i><%= success %></div>
        <% } %>

        <!-- Generar nuevo backup -->
        <div class="backup-section mb-4">
            <h5><i class="bi bi-cloud-download me-2"></i>Generar Nuevo Backup</h5>
            <div class="backup-info">
                <i class="bi bi-info-circle-fill"></i>
                <div>
                    <p class="mb-1">El backup incluye:</p>
                    <ul class="mb-0">
                        <li>Base de datos completa (<code>biblioteca.sql</code>)</li>
                        <li>Portadas de libros (<code>portadas/</code>)</li>
                    </ul>
                    <p class="mb-0 mt-2">
                        <strong>Formato:</strong> backup_YYYY-MM-DD_HH-MM-SS.zip
                    </p>
                </div>
            </div>
            <form method="POST" action="/admin/backup" class="mt-3" id="formBackup">
                <button type="submit" class="btn btn-warning btn-lg" id="btnBackup"
                        onclick="this.innerHTML='<i class=\'bi bi-hourglass-split me-2\'></i>Generando...'; this.disabled=true; this.form.submit();">
                    <i class="bi bi-cloud-download me-2"></i>Generar Backup Ahora
                </button>
            </form>
        </div>

        <!-- Lista de backups existentes -->
        <div class="content-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0"><i class="bi bi-archive me-2"></i>Backups Generados</h5>
                <small class="text-muted"><%= backups.length %> archivo(s) en disco</small>
            </div>

            <% if (backups.length === 0) { %>
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-inbox" style="font-size:2.5rem;"></i>
                    <p class="mt-2">No hay backups generados aún.</p>
                </div>
            <% } else { %>
            <div class="table-responsive">
                <table class="table table-custom">
                    <thead>
                        <tr>
                            <th>Archivo</th>
                            <th>Fecha</th>
                            <th>Tamaño</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% backups.forEach((b, i) => { %>
                        <tr>
                            <td>
                                <i class="bi bi-file-zip text-warning me-2"></i>
                                <code><%= b.nombre %></code>
                                <% if (i === 0) { %>
                                    <span class="badge bg-success ms-2">Más reciente</span>
                                <% } %>
                            </td>
                            <td><small><%= new Date(b.fecha).toLocaleString('es-VE') %></small></td>
                            <td><small><%= b.tamaño %></small></td>
                            <td>
                                <a href="/admin/backup/descargar/<%= encodeURIComponent(b.nombre) %>"
                                   class="btn btn-sm btn-outline-primary me-1">
                                    <i class="bi bi-download"></i> Descargar
                                </a>
                                <form method="POST" action="/admin/backup/eliminar/<%= encodeURIComponent(b.nombre) %>"
                                      style="display:inline;"
                                      onsubmit="return confirm('¿Eliminar este backup?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <% } %>

            <% if (logs) { %>
            <details class="mt-3">
                <summary class="text-muted" style="cursor:pointer;">
                    <small><i class="bi bi-journal-text me-1"></i>Ver log de backups</small>
                </summary>
                <pre class="mt-2" style="background:#f8f9fa;padding:1rem;border-radius:6px;font-size:.8rem;max-height:150px;overflow-y:auto;"><%= logs %></pre>
            </details>
            <% } %>
        </div>
    </div>
</div>
</body>
</html>
