<!DOCTYPE html>
<html lang="es">
<head><title><%= material.titulo %> - Sistema Bibliográfico</title><%- include('../partials/head') %></head>
<body>
<%- include('../partials/navbar_public') %>
<div class="container py-4">
    <div class="d-flex align-items-center mb-3">
        <a href="javascript:history.back()" class="btn-back"><i class="bi bi-arrow-left me-2"></i>Volver a resultados</a>
    </div>
    
    <div class="ficha-container">
        <!-- Fila 1: Portada + Info principal -->
        <div class="row g-3 mb-3">
            <!-- Columna izquierda: Portada -->
            <div class="col-lg-3">
                <div class="ficha-portada-card" style="margin-left: 0;">
                    <% if (material.portada) { %>
                        <img src="<%= material.portada %>" alt="Portada" class="ficha-portada-img" style="margin-left: 0;">
                    <% } else { %>
                        <div class="ficha-portada-placeholder d-flex align-items-center justify-content-center" style="margin-left: 0;">
                            <i class="bi bi-book"></i>
                        </div>
                    <% } %>
                </div>

                <!-- Signatura -->
                <% if (material.signatura) { %>
                <div class="ficha-signatura">
                    <i class="bi bi-geo-alt-fill me-2"></i>
                    <span><strong>Signatura:</strong> <%= material.signatura %></span>
                </div>
                <% } %>
            </div>

            <!-- Columna derecha: Título, autor, tipo/categoría y resumen -->
            <div class="col-lg-9">
                <!-- Título y Disponibilidad en flex -->
                <div class="d-flex align-items-start justify-content-between gap-3 mb-2">
                    <!-- Título -->
                    <h1 class="ficha-titulo mb-0"><%= material.titulo %></h1>
                    <!-- Disponibilidad (esquina superior derecha) -->
                    <div class="ficha-disponibilidad-texto <%= disponibles > 0 ? 'disponible' : 'no-disponible' %> flex-shrink-0">
                        <% if (disponibles > 0) { %>
                            <i class="bi bi-check-circle-fill me-1"></i> Disponible - <%= disponibles %> ejemplar(es)
                        <% } else { %>
                            <i class="bi bi-x-circle-fill me-1"></i> No disponible - <%= material.ejemplares ? material.ejemplares.length : 0 %> ejemplar(es)
                        <% } %>
                    </div>
                </div>
                
                <!-- Autores -->
                <% const autores = material.libro?.autores || material.tesis?.autores || []; %>
                <% if (autores.length > 0) { %>
                <p class="ficha-autores mb-2"><i class="bi bi-person-fill me-2"></i><%= autores.map(a => a.nombre).join(' / ') %></p>
                <% } %>

                <!-- Tipo y Categoría -->
                <div class="ficha-badges">
                    <span class="badge-tipo"><i class="bi bi-tag-fill me-1"></i><%= material.tipo %></span>
                    <span class="badge-categoria"><i class="bi bi-bookmark-fill me-1"></i><%= material.categoria %></span>
                </div>

                <!-- Resumen prominente -->
                <% if (material.resumen) { %>
                <div class="ficha-resumen-box mt-3">
                    <h4 class="ficha-resumen-titulo"><i class="bi bi-file-text me-2"></i>Resumen</h4>
                    <div class="ficha-resumen-texto" id="resumen"><%- material.resumen.replace(/\n/g, '<br>') %></div>
                    <% if (material.resumen.length > 300) { %>
                    <button id="toggleBtn" class="btn-toggle">Ver más</button>
                    <% } %>
                </div>
                <% } %>
            </div>
        </div>

        <!-- Información bibliográfica -->
        <div class="ficha-seccion">
            <h4 class="ficha-seccion-titulo"><i class="bi bi-info-circle me-2"></i>Información Bibliográfica</h4>
            <div class="ficha-info-grid">
                <% if (material.anio) { %>
                <div class="info-item">
                    <div class="info-icono"><i class="bi bi-calendar3"></i></div>
                    <div class="info-datos">
                        <span class="info-label">Año</span>
                        <span class="info-valor"><%= material.anio %></span>
                    </div>
                </div>
                <% } %>
                <% if (material.libro?.isbn) { %>
                <div class="info-item">
                    <div class="info-icono"><i class="bi bi-upc"></i></div>
                    <div class="info-datos">
                        <span class="info-label">ISBN</span>
                        <span class="info-valor"><%= material.libro.isbn %></span>
                    </div>
                </div>
                <% } %>
                <% if (material.libro?.editorial) { %>
                <div class="info-item">
                    <div class="info-icono"><i class="bi bi-building"></i></div>
                    <div class="info-datos">
                        <span class="info-label">Editorial</span>
                        <span class="info-valor"><%= material.libro.editorial %></span>
                    </div>
                </div>
                <% } %>
                <% if (material.revista?.issn) { %>
                <div class="info-item">
                    <div class="info-icono"><i class="bi bi-upc"></i></div>
                    <div class="info-datos">
                        <span class="info-label">ISSN</span>
                        <span class="info-valor"><%= material.revista.issn %></span>
                    </div>
                </div>
                <% } %>
                <% if (material.tesis?.grado) { %>
                <div class="info-item">
                    <div class="info-icono"><i class="bi bi-mortarboard"></i></div>
                    <div class="info-datos">
                        <span class="info-label">Grado</span>
                        <span class="info-valor"><%= material.tesis.grado %></span>
                    </div>
                </div>
                <% } %>
                <% if (material.tesis?.tutor) { %>
                <div class="info-item">
                    <div class="info-icono"><i class="bi bi-person-badge"></i></div>
                    <div class="info-datos">
                        <span class="info-label">Tutor</span>
                        <span class="info-valor"><%= material.tesis.tutor %></span>
                    </div>
                </div>
                <% } %>
                <% if (material.tesis?.institucion) { %>
                <div class="info-item-full">
                    <div class="info-item">
                        <div class="info-icono"><i class="bi bi-bank"></i></div>
                        <div class="info-datos">
                            <span class="info-label">Institución</span>
                            <span class="info-valor"><%= material.tesis.institucion %></span>
                        </div>
                    </div>
                </div>
                <% } %>
                <% if (material.url_digital) { %>
                <div class="info-item-full">
                    <a href="<%= material.url_digital %>" target="_blank" rel="noopener" class="btn-recurso-digital">
                        <i class="bi bi-cloud-download me-2"></i>Acceder a versión digital
                    </a>
                </div>
                <% } %>
            </div>
        </div>

        <!-- Ejemplares -->
        <% if (material.ejemplares && material.ejemplares.length > 0) { %>
        <div class="ficha-ejemplares">
            <h6 class="ficha-ejemplares-titulo">Ejemplares disponibles</h6>
            <div class="ejemplares-lista">
                <% material.ejemplares.forEach(ej => { %>
                <div class="ejemplar-item">
                    <span class="ejemplar-codigo"><i class="bi bi-upc me-1"></i><%= ej.codigo_inventario %></span>
                    <span class="ejemplar-estado <%= ej.estado %>"><%= ej.estado %></span>
                </div>
                <% }) %>
            </div>
        </div>
        <% } %>

        <!-- Artículos de revista -->
        <% if (material.revista?.articulos?.length > 0) { %>
        <div class="ficha-seccion">
            <h4 class="ficha-seccion-titulo"><i class="bi bi-list-ul me-2"></i>Artículos en esta revista</h4>
            <div class="articulos-lista">
                <% material.revista.articulos.forEach(art => { %>
                <div class="articulo-item">
                    <h6 class="articulo-titulo"><%= art.titulo %></h6>
                    <div class="articulo-metadatos">
                        <% if (art.autores?.length > 0) { %>
                        <span><i class="bi bi-person me-1"></i><%= art.autores.map(a=>a.nombre).join(', ') %></span>
                        <% } %>
                        <% if (art.paginas) { %>
                        <span><i class="bi bi-file-text me-1"></i>Págs. <%= art.paginas %></span>
                        <% } %>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
        <% } %>
    </div>
</div>
<style>
.ficha-resumen-texto { max-height: 180px; overflow: hidden; transition: max-height 0.5s ease; }
.ficha-resumen-texto.expanded { max-height: 1000px; }
.btn-toggle { color: var(--color-accent); background: none; border: none; font-weight: 600; cursor: pointer; padding: 0; margin-top: 0.5rem; }
.btn-toggle:hover { text-decoration: underline; }
</style>
<script>
document.addEventListener("DOMContentLoaded", function() {
    const resumen = document.getElementById("resumen");
    const btn = document.getElementById("toggleBtn");
    if (resumen && btn) {
        btn.addEventListener("click", function() {
            resumen.classList.toggle("expanded");
            btn.textContent = resumen.classList.contains("expanded") ? "Ver menos" : "Ver más";
        });
    }
});
</script>
</body>
</html>