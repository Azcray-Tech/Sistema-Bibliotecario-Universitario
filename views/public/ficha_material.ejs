<!DOCTYPE html>
<html lang="es">
<head><title><%= material.titulo %> - Sistema Bibliográfico</title><%- include('../partials/head') %></head>
<body>
<%- include('../partials/navbar_public') %>
<!--<div class="breadcrumb-custom">
    <div class="container">
         <nav aria-label="breadcrumb">
           <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/">Inicio</a></li>
                <li class="breadcrumb-item active"><%= material.titulo.substring(0,50) %><%= material.titulo.length>50?'...':'' %></li>
            </ol>
        </nav>
    </div>
</div>-->
<div class="container mb-5">
    <a href="javascript:history.back()" class="btn-back mb-4"><i class="bi bi-arrow-left"></i>Volver a resultados</a>
    <div class="book-detail-container">
        <div class="row">
            <div class="col-md-4 text-center mb-4 mb-md-0">
                <% if (material.portada) { %>
                    <img src="<%= material.portada %>" alt="Portada" class="book-cover-large">
                <% } else { %>
                    <div class="book-cover-large d-flex align-items-center justify-content-center bg-light mx-auto"
                         style="width:220px;height:300px;border-radius:8px;">
                        <i class="bi bi-book" style="font-size:5rem;color:#ccc;"></i>
                    </div>
                <% } %>

                <div class="availability-box mt-3">
                    <% if (disponibles > 0) { %>
                        <h5><i class="bi bi-check-circle me-2"></i>Disponible</h5>
                        <p class="mb-0"><strong><%= disponibles %></strong> ejemplar(es) disponible(s)</p>
                    <% } else { %>
                        <h5 style="color:#dc3545;"><i class="bi bi-x-circle me-2"></i>No disponible</h5>
                        <p class="mb-0 text-muted">Todos los ejemplares están prestados</p>
                    <% } %>
                    <% if (material.signatura) { %>
                        <p class="mb-0 mt-2"><i class="bi bi-geo-alt me-1"></i><%= material.signatura %></p>
                    <% } %>
                </div>

                <!-- Ejemplares -->
                <% if (material.ejemplares && material.ejemplares.length > 0) { %>
                <div class="mt-3 text-start">
                    <h6 class="text-muted mb-2">Ejemplares</h6>
                    <% material.ejemplares.forEach(ej => { %>
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <small><i class="bi bi-tag me-1"></i><%= ej.codigo_inventario %></small>
                        <span class="badge <%= ej.estado==='disponible'?'bg-success':ej.estado==='prestado'?'bg-warning text-dark':'bg-danger' %>">
                            <%= ej.estado %>
                        </span>
                    </div>
                    <% }) %>
                </div>
                <% } %>
            </div>

            <div class="col-md-8">
                <h1 class="book-title-main"><%= material.titulo %></h1>

                <!-- Autores -->
                <% const autores = material.libro?.autores || material.tesis?.autores || []; %>
                <% if (autores.length > 0) { %>
                <div class="book-author-main">
                    <i class="bi bi-person-fill me-2"></i>
                    <%= autores.map(a => a.nombre).join(' / ') %>
                </div>
                <% } %>

                <!-- Abstract -->
                <% if (material.resumen) { %>
                <div class="actra-section mt-3">
                    <h5><i class="bi bi-file-text-fill me-2"></i>Resumen (ABSTRACT)</h5>
                    <div class="actra-text" id="resumen"><%- material.resumen.replace(/\n/g,'<br>') %></div>
                    <button id="toggleBtn" class="btn btn-link p-0 mt-2">Ver más</button>
                </div>
                <% } %>

                <!-- Badges -->
                <div class="mb-3 mt-3">
                    <span class="badge badge-large" style="background:var(--color-accent);color:white;"><%= material.categoria %></span>
                    <span class="badge badge-large ms-2" style="background:var(--color-secondary);color:white;"><%= material.tipo %></span>
                </div>

                <!-- Info bibliográfica -->
                <div class="info-section mt-4">
                    <div class="row g-3">
                        <% if (material.anio) { %>
                        <div class="col-md-6">
                            <div class="info-card">
                                <div class="info-card-label"><i class="bi bi-calendar me-2"></i>Año</div>
                                <div class="info-card-value"><%= material.anio %></div>
                            </div>
                        </div>
                        <% } %>
                        <% if (material.libro?.isbn) { %>
                        <div class="col-md-6">
                            <div class="info-card">
                                <div class="info-card-label"><i class="bi bi-upc-scan me-2"></i>ISBN</div>
                                <div class="info-card-value"><%= material.libro.isbn %></div>
                            </div>
                        </div>
                        <% } %>
                        <% if (material.libro?.editorial) { %>
                        <div class="col-md-6">
                            <div class="info-card">
                                <div class="info-card-label"><i class="bi bi-building me-2"></i>Editorial</div>
                                <div class="info-card-value"><%= material.libro.editorial %></div>
                            </div>
                        </div>
                        <% } %>
                        <% if (material.revista?.issn) { %>
                        <div class="col-md-6">
                            <div class="info-card">
                                <div class="info-card-label"><i class="bi bi-upc-scan me-2"></i>ISSN</div>
                                <div class="info-card-value"><%= material.revista.issn %></div>
                            </div>
                        </div>
                        <% } %>
                        <% if (material.tesis) { %>
                        <div class="col-md-6">
                            <div class="info-card">
                                <div class="info-card-label"><i class="bi bi-mortarboard me-2"></i>Grado</div>
                                <div class="info-card-value"><%= material.tesis.grado %></div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-card">
                                <div class="info-card-label"><i class="bi bi-person-badge me-2"></i>Tutor</div>
                                <div class="info-card-value"><%= material.tesis.tutor %></div>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="info-card">
                                <div class="info-card-label"><i class="bi bi-bank me-2"></i>Institución</div>
                                <div class="info-card-value"><%= material.tesis.institucion %></div>
                            </div>
                        </div>
                        <% } %>
                        <% if (material.url_digital) { %>
                        <div class="col-md-12">
                            <div class="info-card">
                                <div class="info-card-label"><i class="bi bi-link-45deg me-2"></i>Recurso digital</div>
                                <div class="info-card-value">
                                    <a href="<%= material.url_digital %>" target="_blank" rel="noopener" class="digital-link">
                                        <i class="bi bi-cloud-download"></i> Acceder a versión digital
                                    </a>
                                </div>
                            </div>
                        </div>
                        <% } %>
                    </div>
                </div>

                <!-- Artículos de revista -->
                <% if (material.revista?.articulos?.length > 0) { %>
                <div class="mt-4">
                    <h5><i class="bi bi-list-ul me-2"></i>Artículos en esta revista</h5>
                    <div class="list-group">
                        <% material.revista.articulos.forEach(art => { %>
                        <div class="list-group-item list-group-item-action">
                            <div class="fw-600"><%= art.titulo %></div>
                            <% if (art.autores?.length > 0) { %>
                            <small class="text-muted"><i class="bi bi-person me-1"></i><%= art.autores.map(a=>a.nombre).join(', ') %></small>
                            <% } %>
                            <% if (art.paginas) { %>
                            <small class="text-muted ms-2"><i class="bi bi-file-text me-1"></i>Págs. <%= art.paginas %></small>
                            <% } %>
                        </div>
                        <% }) %>
                    </div>
                </div>
                <% } %>
            </div>
        </div>
    </div>
</div>
<style>
.actra-text { max-height:120px; overflow:hidden; transition:max-height 0.5s ease; }
.actra-text.expanded { max-height:2000px; }
#toggleBtn { color:var(--color-accent); text-decoration:none; font-weight:bold; cursor:pointer; }
</style>
<script>
document.addEventListener("DOMContentLoaded", function() {
    const resumen = document.getElementById("resumen");
    const btn = document.getElementById("toggleBtn");
    if (resumen && btn) btn.addEventListener("click", () => {
        resumen.classList.toggle("expanded");
        btn.textContent = resumen.classList.contains("expanded") ? "Ver menos" : "Ver más";
    });
});
</script>
</body>
</html>
