<!DOCTYPE html>
<html lang="es">
<head><title>Resultados - Sistema Bibliográfico</title><%- include('../partials/head') %></head>
<body>
<%- include('../partials/navbar_public') %>
<div class="hero-search" style="padding:2rem 0;">
    <div class="container text-center">
        <h2>Catálogo Bibliográfico</h2>
    </div>
</div>
<div class="container pb-4">
    <div class="search-container">
        <form action="/buscar" method="GET">
            <div class="row g-2">
                <div class="col-md-10">
                    <input type="text" name="q" class="form-control" placeholder="Buscar por título, autor, ISBN..." value="<%= query.q || '' %>">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-search w-100"><i class="bi bi-search me-2"></i>Buscar</button>
                </div>
            </div>
        </form>
    </div>

    <div class="mt-3">
        <div class="results-header mb-3">
            <div>
                <h5 class="mb-1">Resultados de búsqueda</h5>
                <small class="text-muted">Se encontraron <%= total %> resultado(s)</small>
            </div>
        </div>

        <% if (materiales.length === 0) { %>
            <div class="text-center py-5 text-muted">
                <i class="bi bi-search" style="font-size:3rem;"></i>
                <p class="mt-3">No se encontraron resultados para su búsqueda.</p>
                <a href="/" class="btn btn-primary-custom mt-2">Nueva búsqueda</a>
            </div>
        <% } %>

        <% materiales.forEach(m => { %>
        <div class="book-item" onclick="window.location.href='/material/<%= m.id %>'">
            <% if (m.portada) { %>
                <img src="<%= m.portada %>" alt="Portada" class="book-thumbnail">
            <% } else { %>
                <div class="book-thumbnail d-flex align-items-center justify-content-center bg-light">
                    <i class="bi bi-book" style="font-size:2rem;color:#aaa;"></i>
                </div>
            <% } %>
            <div class="book-info">
                <div class="book-title"><%= m.titulo %></div>
                <div class="book-author"><%= m.autor %></div>
                <div class="book-meta">
                    <% if (m.libro?.isbn) { %><span><i class="bi bi-upc-scan me-1"></i>ISBN: <%= m.libro.isbn %></span><% } %>
                    <% if (m.anio) { %><span><i class="bi bi-calendar3 me-1"></i>Año: <%= m.anio %></span><% } %>
                    <% if (m.libro?.editorial) { %><span><i class="bi bi-building me-1"></i><%= m.libro.editorial %></span><% } %>
                </div>
                <div class="book-footer">
                    <span class="badge-category"><%= m.categoria %></span>
                    <span class="badge-tipo">
                        <% if (m.tipo === 'libro') { %><i class="bi bi-book"></i><% } %>
                        <% if (m.tipo === 'tesis') { %><i class="bi bi-mortarboard"></i><% } %>
                        <% if (m.tipo === 'revista') { %><i class="bi bi-journal-text"></i><% } %>
                        <% if (m.tipo === 'anuario') { %><i class="bi bi-calendar3"></i><% } %>
                        <%= m.tipo %>
                    </span>
                    <span class="badge-availability <%= m.stock > 0 ? 'available' : 'unavailable' %>">
                        <% if (m.stock > 0) { %>
                            <i class="bi bi-check-circle-fill"></i> Disponible (<%= m.stock %>)
                        <% } else { %>
                            <i class="bi bi-x-circle-fill"></i> No disponible
                        <% } %>
                    </span>
                </div>
            </div>
        </div>
        <% }) %>

        <% if (pages > 1) { %>
        <nav class="pagination-custom mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item <%= page<=1?'disabled':'' %>">
                    <a class="page-link" href="/buscar?<%= new URLSearchParams({...query, page: page-1}) %>"><i class="bi bi-chevron-left"></i></a>
                </li>
                <% for(let i=1;i<=pages;i++) { %>
                    <li class="page-item <%= i===page?'active':'' %>">
                        <a class="page-link" href="/buscar?<%= new URLSearchParams({...query, page: i}) %>"><%= i %></a>
                    </li>
                <% } %>
                <li class="page-item <%= page>=pages?'disabled':'' %>">
                    <a class="page-link" href="/buscar?<%= new URLSearchParams({...query, page: page+1}) %>"><i class="bi bi-chevron-right"></i></a>
                </li>
            </ul>
        </nav>
        <% } %>
    </div>
</div>
</body>
</html>